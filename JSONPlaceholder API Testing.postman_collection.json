        {
          "name": "List all Resources",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type is application/json\", function () {\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
                  "        .to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response body is an array\", function () {\r",
                  "    pm.expect(response).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains posts\", function () {\r",
                  "    pm.expect(response.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains 100 posts\", function () {\r",
                  "    pm.expect(response.length).to.eql(100);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each post contains required fields\", function () {\r",
                  "    response.forEach(function (post) {\r",
                  "        pm.expect(post).to.have.all.keys(\r",
                  "            \"userId\",\r",
                  "            \"id\",\r",
                  "            \"title\",\r",
                  "            \"body\"\r",
                  "        );\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Post field data types are correct\", function () {\r",
                  "    response.forEach(function (post) {\r",
                  "        pm.expect(post.userId).to.be.a(\"number\");\r",
                  "        pm.expect(post.id).to.be.a(\"number\");\r",
                  "        pm.expect(post.title).to.be.a(\"string\");\r",
                  "        pm.expect(post.body).to.be.a(\"string\");\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Post IDs are positive numbers\", function () {\r",
                  "    response.forEach(function (post) {\r",
                  "        pm.expect(post.id).to.be.above(0);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Post titles are not empty\", function () {\r",
                  "    response.forEach(function (post) {\r",
                  "        pm.expect(post.title.trim()).to.not.be.empty;\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Post bodies are not empty\", function () {\r",
                  "    response.forEach(function (post) {\r",
                  "        pm.expect(post.body.trim()).to.not.be.empty;\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains 100 posts\", function () {\r",
                  "    pm.expect(response.length).to.eql(100);\r",
                  "})"
                ],
