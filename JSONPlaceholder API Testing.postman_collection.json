        {
          "name": "List Nested Resources (Post comments)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "const expectedPostId = Number(pm.environment.get(\"postId\"));\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type is application/json\", function () {\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
                  "        .to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response body is an array\", function () {\r",
                  "    pm.expect(response).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Comments are returned\", function () {\r",
                  "    pm.expect(response.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"All comments belong to requested post\", function () {\r",
                  "    response.forEach(function (comment) {\r",
                  "        pm.expect(comment.postId).to.eql(expectedPostId);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each comment contains required fields\", function () {\r",
                  "    response.forEach(function (comment) {\r",
                  "        pm.expect(comment).to.have.all.keys(\r",
                  "            \"postId\",\r",
                  "            \"id\",\r",
                  "            \"name\",\r",
                  "            \"email\",\r",
                  "            \"body\"\r",
                  "        );\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Comment field data types are correct\", function () {\r",
                  "    response.forEach(function (comment) {\r",
                  "        pm.expect(comment.postId).to.be.a(\"number\");\r",
                  "        pm.expect(comment.id).to.be.a(\"number\");\r",
                  "        pm.expect(comment.name).to.be.a(\"string\");\r",
                  "        pm.expect(comment.email).to.be.a(\"string\");\r",
                  "        pm.expect(comment.body).to.be.a(\"string\");\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Comment email values have valid format\", function () {\r",
                  "    const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\r",
                  "\r",
                  "    response.forEach(function (comment) {\r",
                  "        pm.expect(comment.email).to.match(emailRegex);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Comment bodies are not empty\", function () {\r",
                  "    response.forEach(function (comment) {\r",
                  "        pm.expect(comment.body.trim()).to.not.be.empty;\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"No duplicate comment IDs are returned\", function () {\r",
                  "    const commentIds = response.map(comment => comment.id);\r",
                  "    const uniqueCommentIds = new Set(commentIds);\r",
                  "\r",
